# --- Majburiy ---
TELEGRAM_BOT_TOKEN=BotFather_dan_olingan_token
ANTHROPIC_API_KEY=sk-ant-...

# Dasturchining (sizning) chat ID. Avval bo'sh qoldiring; botga yozsangiz
# log'da "Chat ID: ..." chiqadi, shu raqamni shu yerga yozing.
DEVELOPER_CHAT_ID=

# --- Ixtiyoriy ---
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS=2000

# Ovozli xabarlar uchun (Whisper). Bo'sh bo'lsa ovoz o'chiriladi.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# GitHub webhook (ixtiyoriy)
GITHUB_WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Sozlamalar
TIMEZONE=Asia/Tashkent
MORNING_HOUR=9
EVENING_HOUR=21
ADVANCE_PERCENT=50
DB_PATH=assistant.db
